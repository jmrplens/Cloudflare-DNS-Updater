---
// Custom Starlight <Head> override.
// Renders Starlight's default head, then layers per-page structured data
// (TechArticle + BreadcrumbList) and per-page Twitter card tags on top.
// The site-wide @graph (Person / WebSite / SoftwareApplication) lives in
// astro.config.mjs; these IDs link the per-page nodes back into that graph.
import Default from "@astrojs/starlight/components/Head.astro";

// Derive origin + base path from Astro config so a domain/base rename needs no
// code change here. PERSON_ID mirrors `authorId` in astro.config.mjs (an
// external identity URL that can't be derived from the site origin).
const SITE = import.meta.env.SITE ?? "https://jmrplens.github.io";
const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const PERSON_ID = "https://jmrp.io/#person";
const WEBSITE_ID = `${SITE}${BASE}/#website`;
// Matches the SoftwareApplication @id in the site-wide @graph (astro.config.mjs).
const SOFTWARE_ID = "https://github.com/jmrplens/Cloudflare-DNS-Updater#software";

// Minimal typed view of the Starlight route data we consume.
interface RouteData {
	entry?: { data?: { title?: string; description?: string } };
	lastUpdated?: Date;
}
const route = (Astro.locals as { starlightRoute?: RouteData }).starlightRoute;
const data = route?.entry?.data ?? {};
const title = data.title ?? "Cloudflare DNS Updater";
const description = data.description ?? "";

const pathname = Astro.url.pathname; // e.g. /Cloudflare-DNS-Updater/configuration/
const canonical = new URL(pathname, SITE).href;
const rel = pathname.startsWith(BASE) ? pathname.slice(BASE.length) : pathname;
const lang = rel.startsWith("/es/") || rel === "/es" ? "es" : "en";
const isHome = rel === "/" || rel === "" || rel === "/es/" || rel === "/es";

// Git-derived last-updated date (Starlight `lastUpdated: true`).
const updated =
	route?.lastUpdated instanceof Date ? route.lastUpdated.toISOString() : undefined;

// TechArticle for every content page (not the splash home).
const techArticle = isHome
	? null
	: {
			"@context": "https://schema.org",
			"@type": "TechArticle",
			headline: title,
			...(description ? { description } : {}),
			inLanguage: lang,
			url: canonical,
			mainEntityOfPage: canonical,
			// Point voice/AI assistants at the page title and lead paragraph.
			speakable: {
				"@type": "SpeakableSpecification",
				cssSelector: ["h1", ".sl-markdown-content > p:first-of-type"],
			},
			...(updated ? { datePublished: updated, dateModified: updated } : {}),
			author: { "@id": PERSON_ID },
			publisher: { "@id": PERSON_ID },
			isPartOf: { "@id": WEBSITE_ID },
			about: { "@id": SOFTWARE_ID },
		};

// BreadcrumbList for every non-home page, with locale-aware labels.
function titleCase(seg: string) {
	return seg.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
}
// Localized labels for the known top-level section segments (slugs stay English
// across locales, so intermediate breadcrumb names need translating).
const SECTION_LABELS: Record<string, { en: string; es: string }> = {
	development: { en: "Development", es: "Desarrollo" },
};
function segLabel(seg: string, locale: "en" | "es") {
	return SECTION_LABELS[seg]?.[locale] ?? titleCase(seg);
}
let breadcrumb = null;
if (!isHome) {
	const homeUrl = lang === "es" ? `${SITE}${BASE}/es/` : `${SITE}${BASE}/`;
	const homeName = lang === "es" ? "Inicio" : "Home";
	const items = [{ "@type": "ListItem", position: 1, name: homeName, item: homeUrl }];
	const segs = rel.split("/").filter(Boolean).filter((s) => s !== "es");
	let acc = lang === "es" ? `${BASE}/es` : BASE;
	segs.forEach((seg, i) => {
		acc += `/${seg}`;
		const last = i === segs.length - 1;
		items.push({
			"@type": "ListItem",
			position: i + 2,
			name: last ? title : segLabel(seg, lang),
			item: new URL(`${acc}/`, SITE).href,
		});
	});
	breadcrumb = {
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: items,
	};
}
---

<Default />

{techArticle && <script type="application/ld+json" is:inline set:html={JSON.stringify(techArticle)} />}
{breadcrumb && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />}
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
